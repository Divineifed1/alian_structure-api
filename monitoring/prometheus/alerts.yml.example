# Example Prometheus alerting rules aligned with the Grafana
# `application-overview` dashboard SLO panels.
#
# Drop this file into the directory configured under `rule_files` in your
# prometheus.yml.

groups:
  - name: alian-structure-api-slo
    interval: 30s
    rules:
      - alert: HighErrorRate
        expr: |
          100 * sum(rate(alian_structure_errors_total[5m]))
            / clamp_min(sum(rate(alian_structure_http_requests_total[5m])), 0.001) > 1
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: 'Alian Structure API error rate above 1%'
          description: 'Error rate has been above 1% for the last 5 minutes (current: {{ $value | printf "%.2f" }}%).'

      - alert: HighP95Latency
        expr: |
          histogram_quantile(0.95,
            sum by (le) (rate(alian_structure_http_request_duration_seconds_bucket[5m]))
          ) > 1
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: 'Alian Structure API p95 latency above 1s'
          description: 'p95 latency has been above 1s for the last 10 minutes (current: {{ $value | printf "%.2f" }}s).'

      - alert: HighEventLoopLag
        expr: alian_structure_nodejs_eventloop_lag_seconds > 0.5
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: 'Node.js event loop lag detected'
          description: 'Event loop lag has been above 0.5s for 5 minutes (current: {{ $value | printf "%.2f" }}s).'

      - alert: HighMemoryUsage
        expr: alian_structure_process_resident_memory_bytes > 1073741824
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: 'Process RSS above 1 GiB'
          description: 'Resident memory has been above 1 GiB for 10 minutes (current: {{ $value | humanize1024 }}B).'

      - alert: PerformanceRegression
        expr: max(alian_structure_performance_regressions_total) > 5
        for: 1m
        labels:
          severity: info
        annotations:
          summary: 'Performance regressions detected'
          description: '{{ $value }} performance regressions have been recorded in the last 24h.'
